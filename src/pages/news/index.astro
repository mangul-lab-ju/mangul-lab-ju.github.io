---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="News & Updates">
	<div class="page-header">
		<div class="container">
			<h1>News & Updates</h1>
			<p>Stay up to date with the latest happenings at Mangul Lab.</p>
		</div>
	</div>

	<div class="container section">
		<div class="grid-cards">
			{sortedNews.map(news => (
				<article class="card news-card">
					{news.data.thumbnail && (
						<img src={news.data.thumbnail} alt="" class="news-card-image" loading="lazy" />
					)}
					<div class="news-content">
						{news.data.highlight && <span class="tag card-actions" style="background-color: var(--color-accent); color: white; display: inline-block;">Highlight</span>}
						<p class="date">{news.data.date.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</p>
						<h3><a href={`/news/${news.id}`} class="clickable-card-link">{news.data.title}</a></h3>
						<p>{news.data.description}</p>
					</div>
				</article>
			))}
		</div>
	</div>
</Layout>

<style>
	.page-header {
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		padding: var(--space-lg) 0;
		text-align: center;
	}

	.page-header h1 {
		color: var(--color-white);
		margin-bottom: var(--space-xs);
	}

	.page-header p {
		color: #cbd5e1;
		font-size: 1.1rem;
	}

	.news-card {
		padding: var(--space-sm);
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.news-card-image {
		width: 90%;
		height: 160px;
		object-fit: cover;
		object-position: center;
		display: block;
		border-radius: var(--radius-sm);
		margin-top: var(--space-xs);
		transition: transform var(--transition-normal);
	}

	.news-card:hover .news-card-image {
		transform: translateY(-2px);
	}

	.news-content {
		padding: var(--space-sm);
		width: 100%;
		flex: 1;
	}

	.date {
		color: var(--color-primary);
		font-weight: 600;
		font-size: 0.9rem;
		margin-bottom: 0.5rem;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.news-card h3 {
		margin-bottom: var(--space-xs);
	}

	.news-card h3 a {
		color: var(--color-text);
	}

	.news-card h3 a:hover {
		color: var(--color-primary);
	}
</style>
