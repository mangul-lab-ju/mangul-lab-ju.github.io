---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allSoftware = await getCollection('software');
const featuredSoftware = allSoftware.filter(s => s.data.featured);
const otherSoftware = allSoftware.filter(s => !s.data.featured);
---

<Layout title="Software Tools">
	<div class="page-header">
		<div class="container">
			<h1>Software Tools</h1>
			<p>Open-source tools developed by the Mangul Lab.</p>
		</div>
	</div>

	<div class="container section">
		{featuredSoftware.length > 0 && (
			<div style="margin-bottom: var(--space-xl);">
				<h2 style="margin-bottom: var(--space-md); border-bottom: 2px solid var(--color-primary); padding-bottom: var(--space-xs); display: inline-block;">Featured Software</h2>
				<div class="grid-cards">
					{featuredSoftware.map(tool => (
						<div class="card software-card featured">
							<div class="card-actions" style="display: flex; justify-content: space-between; align-items: flex-start; position: relative; z-index: 2;">
								<h3>{tool.data.name}</h3>
								<span class="tag" style={tool.data.status === 'Active' ? 'background-color: #dcfce7; color: #166534; display: inline-block;' : 'background-color: #f1f5f9; color: #475569; display: inline-block;'}>
									{tool.data.status}
								</span>
							</div>
							<p>{tool.data.description}</p>
							<a href={tool.data.github} target="_blank" rel="noopener" class="btn btn-secondary mt-md clickable-card-link" style="width: 100%;">View on GitHub</a>
						</div>
					))}
				</div>
			</div>
		)}

		<h2 style="margin-bottom: var(--space-md); border-bottom: 2px solid var(--color-border); padding-bottom: var(--space-xs); display: inline-block;">All Tools</h2>
		<div class="grid-cards">
			{otherSoftware.map(tool => (
				<div class="card software-card">
					<div class="card-actions" style="display: flex; justify-content: space-between; align-items: flex-start; position: relative; z-index: 2;">
						<h3>{tool.data.name}</h3>
						<span class="tag" style={tool.data.status === 'Active' ? 'background-color: #dcfce7; color: #166534; display: inline-block;' : 'background-color: #f1f5f9; color: #475569; display: inline-block;'}>
							{tool.data.status}
						</span>
					</div>
					<p>{tool.data.description}</p>
					<a href={tool.data.github} target="_blank" rel="noopener" class="btn btn-secondary mt-md clickable-card-link" style="width: 100%;">View on GitHub</a>
				</div>
			))}
		</div>
	</div>
</Layout>

<style>
	.page-header {
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		padding: var(--space-lg) 0;
		text-align: center;
	}

	.page-header h1 {
		color: var(--color-white);
		margin-bottom: var(--space-xs);
	}

	.page-header p {
		color: #cbd5e1;
		font-size: 1.1rem;
	}

	.software-card.featured {
		border: 2px solid var(--color-primary);
	}

	.software-card p {
		margin: var(--space-sm) 0;
	}
</style>
