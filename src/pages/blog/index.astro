---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allBlog = await getCollection('blog');
const sortedBlog = allBlog.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog">
	<div class="page-header">
		<div class="container">
			<h1>Blog</h1>
			<p>Insights, tutorials, and thoughts from our researchers.</p>
		</div>
	</div>

	<div class="container section">
		<div class="grid-cards">
			{sortedBlog.map(post => (
				<article class="card blog-card">
					<p class="meta card-actions" style="position: relative; z-index: 2;">
						<span class="date">{post.data.date.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</span> &bull; <span>{post.data.author}</span>
					</p>
					<h3><a href={`/blog/${post.id}`} class="clickable-card-link">{post.data.title}</a></h3>
					<p>{post.data.excerpt}</p>
					<div class="tags mt-md card-actions" style="position: relative; z-index: 2;">
						{post.data.tags.map(tag => <span class="tag" style="display: inline-block;">{tag}</span>)}
					</div>
				</article>
			))}
		</div>
	</div>
</Layout>

<style>
	.page-header {
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		padding: var(--space-lg) 0;
		text-align: center;
	}

	.page-header h1 {
		color: var(--color-white);
		margin-bottom: var(--space-xs);
	}

	.page-header p {
		color: #cbd5e1;
		font-size: 1.1rem;
	}

	.meta {
		color: var(--color-text-muted);
		font-size: 0.9rem;
		margin-bottom: 0.5rem;
	}

	.date {
		color: var(--color-primary);
		font-weight: 500;
	}

	.blog-card h3 {
		margin-bottom: var(--space-xs);
	}

	.blog-card h3 a {
		color: var(--color-text);
	}

	.blog-card h3 a:hover {
		color: var(--color-primary);
	}
</style>
