---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const research = await getCollection('research');
  return research.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Generate APA citation text
const year = entry.data.year;
const title = entry.data.title;
const authors = entry.data.authors.join(', ');
const journal = entry.data.journal;
const doi = entry.data.doi;
const citation = `${authors} (${year}). ${title}. ${journal}. ${doi ? doi : ''}`;
---

<Layout title={entry.data.title}>
	<div class="page-header">
		<div class="container">
			<a href="/research" class="back-link">&larr; Back to Publications</a>
			<h1>{entry.data.title}</h1>
			<p class="authors-large">{entry.data.authors.join(', ')}</p>
		</div>
	</div>

	<div class="container section">
		<div class="pub-details-layout">
			<article class="content">
				{entry.data.image && (
					<div class="pub-image">
						<img src={entry.data.image} alt={entry.data.title} />
					</div>
				)}

				<div class="meta-bar">
					<span class="tag">{entry.data.type}</span>
					<span class="meta-item"><strong>Year:</strong> {entry.data.year}</span>
					<span class="meta-item"><strong>Journal:</strong> {entry.data.journal}</span>
					{entry.data.doi && (
						<span class="meta-item"><strong>DOI/Link:</strong> <a href={entry.data.doi} target="_blank" rel="noopener">Link</a></span>
					)}
				</div>

				<h2>Abstract</h2>
				<div class="prose">
					<Content />
				</div>
			</article>

			<aside class="sidebar">
				<div class="card action-card">
					<h3>Actions</h3>
					<button id="copy-citation" class="btn btn-secondary" style="width: 100%; margin-bottom: var(--space-sm);" data-citation={citation}>
						Copy APA Citation
					</button>
					{entry.data.pdf && (
						<a href={entry.data.pdf} target="_blank" class="btn btn-primary" style="width: 100%;">Download PDF</a>
					)}
				</div>

				<div class="card tags-card" style="margin-top: var(--space-md);">
					<h3>Keywords</h3>
					<div class="tags-container">
						{entry.data.tags.map(tag => (
							<span class="tag">{tag}</span>
						))}
					</div>
				</div>
			</aside>
		</div>
	</div>
</Layout>

<script>
	const copyBtn = document.getElementById('copy-citation');
	if (copyBtn) {
		copyBtn.addEventListener('click', () => {
			const citation = copyBtn.getAttribute('data-citation');
			if (citation) {
				navigator.clipboard.writeText(citation).then(() => {
					const originalText = copyBtn.innerText;
					copyBtn.innerText = 'Copied!';
					setTimeout(() => {
						copyBtn.innerText = originalText;
					}, 2000);
				});
			}
		});
	}
</script>

<style>
	.page-header {
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		padding: var(--space-lg) 0;
	}

	.page-header h1 {
		color: var(--color-white);
		margin-bottom: var(--space-xs);
		font-size: 2.5rem;
	}

	.back-link {
		color: #cbd5e1;
		display: inline-block;
		margin-bottom: var(--space-sm);
		font-weight: 500;
	}

	.back-link:hover {
		color: var(--color-white);
	}

	.authors-large {
		color: #cbd5e1;
		font-size: 1.2rem;
	}

	.pub-details-layout {
		display: grid;
		grid-template-columns: 1fr 300px;
		gap: var(--space-xl);
	}

	@media (max-width: 768px) {
		.pub-details-layout {
			grid-template-columns: 1fr;
		}
	}

	.pub-image {
		width: 100%;
		border-radius: var(--radius-md);
		overflow: hidden;
		margin-bottom: var(--space-md);
		background-color: var(--color-bg);
	}

	.pub-image img {
		width: 100%;
		height: auto;
		display: block;
	}

	.meta-bar {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-md);
		align-items: center;
		padding: var(--space-sm) 0;
		border-bottom: 1px solid var(--color-border);
		margin-bottom: var(--space-lg);
	}

	.meta-item {
		color: var(--color-text-muted);
	}

	.prose h2 {
		margin-top: var(--space-lg);
	}

	.prose p {
		margin-bottom: var(--space-sm);
		text-align: justify;
	}

	.tags-container {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
</style>
