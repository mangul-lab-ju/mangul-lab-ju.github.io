---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { truncateText } from '../utils/text';

const allResources = await getCollection('resources');
const featuredResources = allResources.filter(r => r.data.featured);
const otherResources = allResources.filter(r => !r.data.featured);
---

<Layout title="Resources">
	<div class="page-header">
		<div class="container">
			<h1>Resources & Tutorials</h1>
			<p>Guides, datasets, and educational materials from our lab.</p>
		</div>
	</div>

	<div class="container section">
		{featuredResources.length > 0 && (
			<div style="margin-bottom: var(--space-xl);">
				<h2 style="margin-bottom: var(--space-md); border-bottom: 2px solid var(--color-primary); padding-bottom: var(--space-xs); display: inline-block;">Featured Resources</h2>
				<div class="grid-cards">
					{featuredResources.map(resource => (
						<div class="card resource-card featured">
							<h3><a href={`/resources/${resource.id}`} class="clickable-card-link">{resource.data.title}</a></h3>
							<p>{truncateText(resource.data.description, 35)}</p>
							<div class="tags card-actions" style="position: relative; z-index: 2;">
								{resource.data.tags.map(tag => <span class="tag" style="display: inline-block;">{tag}</span>)}
							</div>
						</div>
					))}
				</div>
			</div>
		)}

		<h2 style="margin-bottom: var(--space-md); border-bottom: 2px solid var(--color-border); padding-bottom: var(--space-xs); display: inline-block;">All Resources</h2>
		<div class="grid-cards">
			{otherResources.map(resource => (
				<div class="card resource-card">
					<h3><a href={`/resources/${resource.id}`} class="clickable-card-link">{resource.data.title}</a></h3>
					<p>{truncateText(resource.data.description, 35)}</p>
					<div class="tags card-actions" style="position: relative; z-index: 2;">
						{resource.data.tags.map(tag => <span class="tag" style="display: inline-block;">{tag}</span>)}
					</div>
				</div>
			))}
		</div>

		<h2 style="margin-top: var(--space-xl); margin-bottom: var(--space-md); border-bottom: 2px solid var(--color-border); padding-bottom: var(--space-xs); display: inline-block;">Bioinformatics for Ukraine</h2>
		<div style="display: flex; gap: var(--space-lg); align-items: flex-start; flex-wrap: wrap;">
			<div style="flex: 1; min-width: 300px;">
				<p>Kick off the season by showing your support for <a href="http://bioinformaticsforukraine.com/">Bioinformatics for Ukraine</a>, a noble initiative aimed at support for Ukrainian scientists and students whose lives have been deeply affected by the ongoing conflict.</p>
				<p>Donating is quick and easy – simply click on the Donate Now button, and your generosity will provide essential support to both aspiring and current fellows of the Bioinformatics for Ukraine initiative.</p>
				<a href="https://www.betterunite.com/bioinformaticsforukraine-empowerdreamsscholarshipfundforukrainianscholars" target="_blank" class="btn btn-primary mt-sm">Donate Now</a>
			</div>
		</div>

		<h2 style="margin-top: var(--space-xl); margin-bottom: var(--space-md); border-bottom: 2px solid var(--color-border); padding-bottom: var(--space-xs); display: inline-block;">Funding Opportunities</h2>
		<p>We are prepared to help our members apply for internal and external awards for research, travel, and education support!</p>
		<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-lg); margin-top: var(--space-md);">
			<div class="card">
				<h3 style="margin-bottom: var(--space-sm);">Undergraduate</h3>
				<ul style="padding-left: var(--space-md);">
					<li><a href="https://undergrad.usc.edu/experience/research/undergrad_research/">USC Provost Undergrad Research Fellowships</a></li>
					<li><a href="https://dornsife.usc.edu/soar">USC Dornsife SOAR</a></li>
					<li><a href="https://dornsife.usc.edu/surf-shure/">USC Dornsife SURF</a></li>
					<li><a href="https://goldwater.scholarsapply.org/eligibility/">Goldwater Scholarship</a></li>
					<li><a href="https://cra.org/crae/awards/cra-outstanding-undergraduate-researchers/">CRA Outstanding Undergraduate Researcher Awards</a></li>
				</ul>
			</div>
			<div class="card">
				<h3 style="margin-bottom: var(--space-sm);">Graduate & Postdoc</h3>
				<ul style="padding-left: var(--space-md);">
					<li><a href="https://www.nsfgrfp.org/">NSF GRFP</a></li>
					<li><a href="https://sites.nationalacademies.org/PGA/FordFellowships/PGA_171962">Ford Foundation Predoctoral Fellowship</a></li>
					<li><a href="https://sites.nationalacademies.org/PGA/FordFellowships/PGA_171939">Ford Foundation Dissertation Fellowship</a></li>
					<li><a href="https://sites.nationalacademies.org/PGA/FordFellowships/PGA_171940">Ford Foundation Postdoctoral Fellowship</a></li>
				</ul>
			</div>
		</div>
	</div>
</Layout>

<style>
	.page-header {
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		padding: var(--space-lg) 0;
		text-align: center;
	}

	.page-header h1 {
		color: var(--color-white);
		margin-bottom: var(--space-xs);
	}

	.page-header p {
		color: #cbd5e1;
		font-size: 1.1rem;
	}

	.resource-card.featured {
		border: 2px solid var(--color-primary);
	}

	.resource-card h3 a {
		color: var(--color-text);
	}

	.resource-card h3 a:hover {
		color: var(--color-primary);
	}

	.tags {
		margin-top: var(--space-md);
	}
</style>
