---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const galleryEvents = await getCollection('gallery');
  return galleryEvents.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={entry.data.title}>
	<div class="page-header">
		<div class="container">
			<a href="/gallery" class="back-link">&larr; Back to Gallery</a>
			<p class="date">{entry.data.date.toLocaleDateString(undefined, { year: 'numeric', month: 'long', day: 'numeric' })}</p>
			<h1>{entry.data.title}</h1>
		</div>
	</div>

	<div class="container section">
		<article class="content-wrapper mb-lg">
			<div class="prose">
				<Content />
			</div>
		</article>

		<hr style="margin: var(--space-lg) 0; border: none; border-top: 1px solid var(--color-border);" />

		<div class="gallery-grid">
			{entry.data.images.map((img, index) => (
				<div class="gallery-item" data-full={img} data-title={`${entry.data.title} - Image ${index + 1}`}>
					<img src={img} alt={`Gallery image ${index + 1}`} loading="lazy" />
					<div class="overlay">
						<span class="title">View</span>
					</div>
				</div>
			))}
		</div>
	</div>

	<!-- Lightbox -->
	<div id="lightbox" class="lightbox">
		<span class="close">&times;</span>
		<img class="lightbox-content" id="lightbox-img" />
		<div id="caption"></div>
	</div>
</Layout>

<script>
	const lightbox = document.getElementById('lightbox');
	const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
	const captionText = document.getElementById('caption');
	const closeBtn = document.querySelector('.close');
	const items = document.querySelectorAll('.gallery-item');

	items.forEach(item => {
		item.addEventListener('click', function(this: HTMLElement) {
			if (lightbox && lightboxImg && captionText) {
				lightbox.style.display = 'flex';
				lightboxImg.src = this.dataset.full!;
				captionText.innerHTML = this.dataset.title!;
			}
		});
	});

	if (closeBtn && lightbox) {
		closeBtn.addEventListener('click', () => {
			lightbox.style.display = 'none';
		});
	}

	if (lightbox) {
		lightbox.addEventListener('click', (e) => {
			if (e.target === lightbox) {
				lightbox.style.display = 'none';
			}
		});
	}
</script>

<style>
	.page-header {
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		padding: var(--space-lg) 0;
		text-align: center;
	}

	.back-link {
		color: #cbd5e1;
		display: inline-block;
		margin-bottom: var(--space-md);
		font-weight: 500;
	}

	.back-link:hover {
		color: var(--color-white);
	}

	.date {
		color: #cbd5e1;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 1px;
		margin-bottom: var(--space-xs);
	}

	.page-header h1 {
		color: var(--color-white);
		max-width: 800px;
		margin: 0 auto;
		font-size: 2.5rem;
	}

	.content-wrapper {
		max-width: 800px;
		margin: 0 auto;
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
		gap: var(--space-sm);
	}

	.gallery-item {
		position: relative;
		overflow: hidden;
		border-radius: var(--radius-md);
		cursor: pointer;
		aspect-ratio: 4/3;
		border: 4px solid var(--color-white);
		box-shadow: var(--shadow-md);
		background-color: var(--color-bg);
	}

	.gallery-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		display: block;
		transition: transform var(--transition-normal);
	}

	.gallery-item:hover img {
		transform: scale(1.05);
	}

	.overlay {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		background: linear-gradient(transparent, rgba(0,0,0,0.8));
		padding: var(--space-md) var(--space-sm) var(--space-sm);
		color: white;
		opacity: 0;
		transition: opacity var(--transition-fast);
		text-align: center;
	}

	.gallery-item:hover .overlay {
		opacity: 1;
	}

	.title {
		font-weight: 500;
	}

	/* Lightbox CSS */
	.lightbox {
		display: none;
		position: fixed;
		z-index: 100;
		padding-top: 50px;
		left: 0;
		top: 0;
		width: 100%;
		height: 100%;
		overflow: auto;
		background-color: rgba(0,0,0,0.9);
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}

	.lightbox-content {
		max-width: 90%;
		max-height: 80vh;
		object-fit: contain;
	}

	#caption {
		margin: auto;
		display: block;
		width: 80%;
		max-width: 700px;
		text-align: center;
		color: #ccc;
		padding: 10px 0;
		height: 150px;
	}

	.close {
		position: absolute;
		top: 15px;
		right: 35px;
		color: #f1f1f1;
		font-size: 40px;
		font-weight: bold;
		cursor: pointer;
	}

	.close:hover,
	.close:focus {
		color: #bbb;
		text-decoration: none;
		cursor: pointer;
	}
</style>
